# =====================================================
# Variables de entorno del servidor Bowtie
# =====================================================
# Copie este archivo como `.env` y ajuste los valores.

# --- Modo de ejecución ---
NODE_ENV=development
PORT=3001

# --- Conexión a PostgreSQL ---
# Opción A: cadena de conexión completa (recomendada en producción / Railway)
# DATABASE_URL=postgres://usuario:password@host:5432/bowtie

# Opción B: parámetros individuales (uso local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bowtie
DB_USER=postgres
DB_PASSWORD=postgres

# Forzar SSL (true por defecto cuando se usa DATABASE_URL en Railway)
# PGSSL=false
